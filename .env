# SSLCommerz Payment Gateway
SSLCOMMERZ_STORE_ID=your-store-id
SSLCOMMERZ_STORE_PASSWORD=your-store-password
SSLCOMMERZ_IS_LIVE=false
SSLCOMMERZ_SUCCESS_URL=http://localhost:3000/api/v1/payments/success
SSLCOMMERZ_FAIL_URL=http://localhost:3000/api/v1/payments/fail
SSLCOMMERZ_CANCEL_URL=http://localhost:3000/api/v1/payments/cancel
SSLCOMMERZ_IPN_URL=http://localhost:3000/api/v1/payments/ipn

# File Upload Configuration
UPLOAD_LOCATION=./uploads
MAX_FILE_SIZE=10485760 # 10MB in bytes
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_VIDEO_TYPES=video/mp4,video/webm
ALLOWED_DOCUMENT_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# AWS S3 (Optional - for production)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=your-bucket-name
AWS_S3_URL=https://your-bucket.s3.amazonaws.com

# CloudFront CDN (Optional)
CDN_URL=https://your-cdn.cloudfront.net

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_FILE_PATH=./logs

# Monitoring (Optional)
SENTRY_DSN=your-sentry-dsn
NEW_RELIC_LICENSE_KEY=your-new-relic-key

# WebSocket
WS_PORT=3001
WS_PATH=/ws

# Cron Jobs
ENABLE_CRON_JOBS=true

# Platform Fee (in percentage)
PLATFORM_FEE_PERCENTAGE=10
PLATFORM_TAX_PERCENTAGE=5

# Withdrawal Settings
MIN_WITHDRAWAL_AMOUNT=500
WITHDRAWAL_FEE_PERCENTAGE=2

# Session Configuration
MAX_SESSIONS_PER_USER=5
SESSION_EXPIRY_DAYS=7

# Security
BCRYPT_ROUNDS=12
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=30

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Search
SEARCH_MIN_QUERY_LENGTH=3
SEARCH_MAX_RESULTS=50

# Cache TTL (in seconds)
CACHE_TTL_SHORT=300 # 5 minutes
CACHE_TTL_MEDIUM=3600 # 1 hour
CACHE_TTL_LONG=86400 # 24 hours


# Feature Flags
ENABLE_GOOGLE_AUTH=true
ENABLE_APPLE_AUTH=true
ENABLE_SMS_VERIFICATION=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_TWO_FACTOR_AUTH=false
ENABLE_GEOLOCATION=true
ENABLE_PUSH_NOTIFICATIONS=true

# Admin Settings
SUPER_ADMIN_EMAIL=admin@servicemarketplace.com
SUPER_ADMIN_PASSWORD=SuperSecurePassword123!

# Booking Settings
BOOKING_AUTO_ACCEPT=false
BOOKING_CANCELLATION_HOURS=24
BOOKING_REMINDER_HOURS=24

# Review Settings
REVIEW_EDIT_WINDOW_HOURS=24
MIN_REVIEW_RATING=1
MAX_REVIEW_RATING=5

# Subscription Settings
FREE_PLAN_MAX_JOBS=3
BASIC_PLAN_MAX_JOBS=10
STANDARD_PLAN_MAX_JOBS=50
PREMIUM_PLAN_MAX_JOBS=-1 # unlimited

# Notification Settings
NOTIFICATION_BATCH_SIZE=100
NOTIFICATION_RETRY_ATTEMPTS=3

# File Storage (local/s3)
STORAGE_TYPE=local

# Image Processing
IMAGE_THUMBNAIL_WIDTH=300
IMAGE_THUMBNAIL_HEIGHT=300
IMAGE_LARGE_WIDTH=1200
IMAGE_LARGE_HEIGHT=1200
IMAGE_QUALITY=85

# Video Processing
VIDEO_MAX_DURATION_SECONDS=300
VIDEO_THUMBNAIL_AT_SECOND=1

# Maintenance Mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=We are currently performing scheduled maintenance. Please check back soon.