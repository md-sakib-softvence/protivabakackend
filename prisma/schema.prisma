generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                          String             @id @default(cuid())
  email                       String             @unique
  phone                       String?            @unique
  password                    String?
  firstName                   String
  lastName                    String
  bio                         String?
  avatar                      String?
  streetAddress               String?
  city                        String?
  state                       String?
  zipCode                     String?
  yearsOfExprience            String?
  nidNumber                   String?
  nidImage                    String?
  country                     String             @default("BD")
  role                        UserRole           @default(CLIENT)
  status                      UserStatus         @default(PENDING)
  verificationStatus          VerificationStatus @default(UNVERIFIED)
  emailVerified               Boolean            @default(false)
  phoneVerified               Boolean            @default(false)
  twoFactorEnabled            Boolean            @default(false)
  twoFactorSecret             String?
  refreshToken                String?
  googleId                    String?            @unique
  appleId                     String?            @unique
  otp                         String?
  fcmToken                    String?
  isProviderRecomendation     Boolean            @default(false)
  otpExpiry                   DateTime?
  otpAttempts                 Int                @default(0)
  lastLogin                   DateTime?
  lastActive                  DateTime?
  providerServiceAvailability Boolean            @default(true)
  loginAttempts               Int                @default(0)
  lockedUntil                 DateTime?
  language                    String             @default("en")
  timezone                    String             @default("Asia/Dhaka")
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt
  deletedAt                   DateTime?
  isContactInfoPublic         Boolean            @default(true)
  isProfilePublic             Boolean            @default(true)
  isNotificationEnabled       Boolean            @default(true)
  isBookingReminderEnabled    Boolean            @default(true)

  clientBookings   Booking[]        @relation("ClientBookings")
  providerBookings Booking[]        @relation("ProviderBookings")
  adminPermissions AdminPermission?
  bookings         Booking[]
  contactInfo      ContactInfo?
  jobs             Job[]
  receivedMessages Message[]        @relation("MessageReceiver")
  sentMessages     Message[]        @relation("MessageSender")
  notifications    Notification[]
  payments         Payment[]
  providerProfile  ProviderProfile?
  receivedReviews  Review[]         @relation("ReviewReceiver")
  sentReviews      Review[]         @relation("ReviewSender")
  sessions         Session[]
  settings         UserSetting?
  withdrawals      Withdrawal[]
  wallet           Wallet?

  @@index([email])
  @@index([phone])
  @@index([role, status])
  @@index([createdAt])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  deviceId     String
  deviceName   String?
  ipAddress    String
  userAgent    String
  refreshToken String   @unique
  isActive     Boolean  @default(true)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("sessions")
}

model ProviderProfile {
  id                 String        @id @default(cuid())
  userId             String        @unique
  profession         String?
  yearsOfExperience  Int?
  hourlyRate         Decimal?      @db.Decimal(10, 2)
  nidNumber          String?
  nidFrontImage      String?
  nidBackImage       String?
  tradeLicense       String?
  serviceRadius      Int?
  availableFrom      String?
  languages          String[]      @default([])
  totalEarnings      Decimal       @default(0) @db.Decimal(12, 2)
  availableBalance   Decimal       @default(0) @db.Decimal(12, 2)
  pendingBalance     Decimal       @default(0) @db.Decimal(12, 2)
  totalJobs          Int           @default(0)
  completedJobs      Int           @default(0)
  canceledJobs       Int           @default(0)
  averageRating      Decimal?      @db.Decimal(3, 2)
  totalReviews       Int           @default(0)
  subscriptionId     String?
  subscriptionExpiry DateTime?
  subscriptionStatus String        @default("FREE")
  isAvailable        Boolean       @default(true)
  isVerified         Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  subscription       Subscription? @relation(fields: [subscriptionId], references: [id])
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isAvailable, isVerified])
  @@index([subscriptionExpiry])
  @@map("provider_profiles")
}

model ContactInfo {
  id        String   @id @default(cuid())
  userId    String   @unique
  facebook  String?
  twitter   String?
  instagram String?
  youtube   String?
  website   String?
  linkedin  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("contact_info")
}

model UserSetting {
  id                  String   @id @default(cuid())
  userId              String   @unique
  isPublicProfile     Boolean  @default(true)
  isShowContactInfo   Boolean  @default(true)
  isShowEmail         Boolean  @default(false)
  isShowPhone         Boolean  @default(false)
  notificationEnabled Boolean  @default(true)
  emailNotification   Boolean  @default(true)
  smsNotification     Boolean  @default(true)
  pushNotification    Boolean  @default(true)
  bookingReminder     Boolean  @default(true)
  newBookingAlert     Boolean  @default(true)
  messageNotification Boolean  @default(true)
  darkMode            Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model AdminPermission {
  id     String @id @default(cuid())
  userId String @unique
  // permissions          Permission[]

  // Booking
  isViewBooking   Boolean @default(false)
  isManageBooking Boolean @default(false)
  isExportBooking Boolean @default(false)

  // Provider
  isViewProvider   Boolean @default(false)
  isManageProvider Boolean @default(false)

  // User
  isViewUser   Boolean @default(false)
  isManageUser Boolean @default(false)

  // Category
  isViewCategory   Boolean @default(false)
  isManageCategory Boolean @default(false)

  // transection
  isViewTransaction  Boolean @default(false)
  // withdrawal
  isViewWithdrawal   Boolean @default(false)
  isManageWithdrawal Boolean @default(false)

  grantedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_permissions")
}

model Category {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  description   String?
  icon          String?
  image         String?
  displayOrder  Int           @default(0)
  isActive      Boolean       @default(true)
  isDelete      Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  jobs          Job[]
  subCategories SubCategory[]

  @@index([slug])
  @@index([isActive, displayOrder])
  @@map("categories")
}

model SubCategory {
  id           String   @id @default(cuid())
  categoryId   String
  name         String
  slug         String
  description  String?
  icon         String?
  image        String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  isDelete     Boolean  @default(false)
  updatedAt    DateTime @updatedAt
  jobs         Job[]
  category     Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, slug])
  @@index([categoryId, isActive])
  @@map("sub_categories")
}

model Job {
  id              String       @id @default(cuid())
  userId          String
  categoryId      String
  subCategoryId   String?
  title           String
  slug            String?
  description     String
  basePrice       Decimal      @db.Decimal(10, 2)
  priceType       PriceType
  includeService  String[]
  thumbnail       String?
  features        Json?
  images          String[]     @default([])
  videos          String[]     @default([])
  serviceLocation String?
  serviceRadius   Int?
  status          JobStatus    @default(DRAFT)
  views           Int          @default(0)
  clicks          Int          @default(0)
  totalBookings   Int          @default(0)
  averageRating   Decimal?     @db.Decimal(3, 2)
  metaTitle       String?
  metaDescription String?
  publishedAt     DateTime?
  isPopuler       Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?
  isDelete        Boolean      @default(false)
  bookings        Booking[]
  category        Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subCategory     SubCategory? @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews         Review[]

  @@index([userId, status])
  @@index([categoryId, status])
  @@index([slug])
  @@index([createdAt])
  @@map("jobs")
}

model Booking {
  id                 String             @id @default(cuid())
  bookingNumber      String?
  clientId           String
  providerId         String
  jobId              String
  serviceName        String
  serviceDescription String?
  preferredDate      DateTime?
  preferredTime      String?
  scheduledAt        DateTime?
  serviceLocation    ServiceLocation
  locationAddress    String?
  locationLatitude   Decimal?           @db.Decimal(10, 8)
  locationLongitude  Decimal?           @db.Decimal(11, 8)
  locationDetails    String?
  contactPhone       String
  contactEmail       String?
  serviceAmount      Decimal            @db.Decimal(10, 2)
  platformFee        Decimal?           @db.Decimal(10, 2)
  taxAmount          Decimal?           @default(0) @db.Decimal(10, 2)
  totalAmount        Decimal?           @db.Decimal(10, 2)
  paymentMethod      String?
  paymentStatus      PaymentStatus      @default(PENDING)
  paidAt             DateTime?
  status             BookingStatus      @default(PENDING)
  cancellationReason String?
  cancelledBy        String?
  cancelledAt        DateTime?
  message            String?
  completedAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  client             User               @relation("ClientBookings", fields: [clientId], references: [id], onDelete: Cascade)
  provider           User               @relation("ProviderBookings", fields: [providerId], references: [id], onDelete: Cascade)
  job                Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  payment            Payment?           @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  review             Review?
  user               User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String?
  paymentId          String?
  locationUpdates    LocationUpdate[]
  callSessions       CallSession[]
  conversationRooms  ConversationRoom[]

  @@index([clientId, status])
  @@index([providerId, status])
  @@index([jobId])
  @@index([bookingNumber])
  @@index([createdAt])
  @@index([scheduledAt])
  @@map("bookings")
}

model Payment {
  id              String         @id @default(cuid())
  transactionId   String         @unique
  bookingId       String
  userId          String
  gateway         PaymentGateway @default(SSLCOMMERZ)
  method          String?
  amount          Decimal        @db.Decimal(10, 2)
  currency        String         @default("BDT")
  gatewayTxnId    String?
  gatewayResponse Json?
  status          PaymentStatus  @default(PENDING)
  failureReason   String?
  metadata        Json?
  initiatedAt     DateTime       @default(now())
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([userId])
  @@index([transactionId])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

model Subscription {
  id              String            @id @default(cuid())
  name            String
  slug            String            @unique
  planType        SubscriptionPlan
  price           Decimal           @db.Decimal(10, 2)
  currency        String            @default("BDT")
  durationDays    Int
  features        Json
  maxJobs         Int?
  maxImages       Int?
  priorityListing Boolean           @default(false)
  isActive        Boolean           @default(true)
  displayOrder    Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  providers       ProviderProfile[]

  @@index([planType, isActive])
  @@map("subscriptions")
}

model Withdrawal {
  id                             String             @id @default(cuid())
  withdrawalNumber               String?
  userId                         String
  amount                         Decimal            @db.Decimal(10, 2)
  fee                            Decimal            @default(0) @db.Decimal(10, 2)
  netAmount                      Decimal            @db.Decimal(10, 2)
  bankName                       String?
  accountNumber                  String?
  accountHolderName              String?
  branchName                     String?
  routingNumber                  String?
  phoneNumber                    String?
  mobileBankingType              MobileBankingType?
  mobileBankingPaymentTakeNumber String?
  bankType                       BankType
  status                         WithdrawalStatus   @default(PENDING)
  processedBy                    String?
  processedAt                    DateTime?
  rejectionReason                String?
  requestedAt                    DateTime           @default(now())
  createdAt                      DateTime           @default(now())
  updatedAt                      DateTime           @updatedAt
  user                           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status])
  @@index([createdAt])
  @@map("withdrawals")
}

model Wallet {
  id     String @id @default(uuid())
  userId String @unique
  amount Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id           String   @id @default(cuid())
  bookingId    String   @unique
  senderId     String
  receiverId   String
  jobId        String
  rating       Int      @db.SmallInt
  comment      String?
  images       String[] @default([])
  helpfulCount Int      @default(0)
  reportCount  Int      @default(0)
  isVisible    Boolean  @default(true)
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  booking      Booking  @relation(fields: [bookingId], references: [id])
  receiver     User     @relation("ReviewReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender       User     @relation("ReviewSender", fields: [senderId], references: [id], onDelete: Cascade)
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([receiverId, isVisible])
  @@index([createdAt])
  @@map("reviews")
}

model Message {
  id          String      @id @default(cuid())
  senderId    String
  receiverId  String
  content     String
  messageType MessageType @default(TEXT)
  mediaUrl    String?
  isRead      Boolean     @default(false)
  readAt      DateTime?
  isDeleted   Boolean     @default(false)
  deletedAt   DateTime?
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender   User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId, createdAt])
  @@index([receiverId, isRead])
  @@map("messages")
}

model Marketing {
  id           String       @id @default(cuid())
  title        String
  description  String?
  image        String
  link         String?
  targetRole   String?
  startDate    DateTime
  endDate      DateTime
  status       BannerStatus @default(DRAFT)
  impressions  Int          @default(0)
  clicks       Int          @default(0)
  displayOrder Int          @default(0)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status, startDate, endDate])
  @@map("marketing")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  actionUrl String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@map("activity_logs")
}

// ── NEW: MESSAGING ROOMS ─────────────────────────────────────────────────────
// ─────────────────────────────────────────────────────────────────────────────

model ConversationRoom {
  id         String    @id @default(cuid())
  bookingId  String    @unique
  clientId   String
  providerId String
  isActive   Boolean   @default(true)
  expiresAt  DateTime? // set when booking completes/cancels
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime? // soft-delete of whole room

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([clientId, providerId])
  @@index([isActive])
  @@map("conversation_rooms")
}

// ─────────────────────────────────────────────────────────────────────────────
// ── NEW: LOCATION TRACKING ───────────────────────────────────────────────────
// ─────────────────────────────────────────────────────────────────────────────

model LocationUpdate {
  id        String       @id @default(cuid())
  bookingId String
  userId    String
  role      TrackingRole
  latitude  Decimal      @db.Decimal(10, 8)
  longitude Decimal      @db.Decimal(11, 8)
  accuracy  Float? // meters
  heading   Float? // degrees 0–360
  speed     Float? // m/s
  altitude  Float? // meters
  timestamp DateTime     @default(now())
  createdAt DateTime     @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId, userId, timestamp])
  @@index([bookingId, timestamp])
  @@map("location_updates")
}

// ─────────────────────────────────────────────────────────────────────────────
// ── NEW: CALL SESSIONS ───────────────────────────────────────────────────────
// ─────────────────────────────────────────────────────────────────────────────

model CallSession {
  id        String       @id @default(cuid())
  bookingId String
  callerId  String
  calleeId  String
  roomId    String       @unique // WebRTC channel or Agora channel name
  provider  CallProvider @default(WEBRTC)
  type      CallType     @default(VOICE)
  status    CallStatus   @default(INITIATED)
  startedAt DateTime?
  endedAt   DateTime?
  duration  Int? // seconds
  metadata  Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([callerId, calleeId])
  @@index([status])
  @@map("call_sessions")
}

enum UserRole {
  SUPER_ADMIN
  SUB_ADMIN
  PROVIDER
  CLIENT
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum Permission {
  VIEW_BOOKINGS
  MANAGE_BOOKINGS
  EXPORT_BOOKINGS
  VIEW_PROVIDERS
  MANAGE_PROVIDERS
  APPROVE_PROVIDERS
  VIEW_USERS
  MANAGE_USERS
  BAN_USERS
  VIEW_CATEGORIES
  MANAGE_CATEGORIES
  MANAGE_SERVICES
  VIEW_SUBSCRIPTIONS
  MANAGE_SUBSCRIPTIONS
  VIEW_TRANSACTIONS
  MANAGE_WITHDRAWALS
  MANAGE_MARKETING
  VIEW_ANALYTICS
  MANAGE_SETTINGS
  FULL_ACCESS
}

enum JobStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
  DELETED
}

enum PriceType {
  FIXED
  HOURLY
  NEGOTIABLE
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REFUNDED
}

enum BookingCompliteInProgress {
  IN_PROGRESS
  COMPLETED
}

enum ServiceLocation {
  CUSTOMER_LOCATION
  PROVIDER_LOCATION
}

enum PaymentGateway {
  SSLCOMMERZ
  STRIPE
  PAYPAL
  CASH
}

// ENUMS — new
// ─────────────────────────────────────────────────────────────────────────────

enum TrackingRole {
  CLIENT
  PROVIDER
}

enum CallProvider {
  WEBRTC
  AGORA
  TWILIO
}

enum CallType {
  VOICE
  VIDEO
}

enum CallStatus {
  INITIATED
  RINGING
  ACCEPTED
  ONGOING
  ENDED
  MISSED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum SubscriptionPlan {
  FREE
  BASIC
  STANDARD
  PREMIUM
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
  CANCELLED
}

enum BankType {
  CARD_PAYMENT
  MOBILE_BANKING
}

enum MobileBankingType {
  BKASH
  NAGAD
  ROCKET
  UPAY
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  FILE
  LOCATION
}

enum BannerStatus {
  DRAFT
  ACTIVE
  SCHEDULED
  EXPIRED
  DEACTIVATED
}

enum NotificationType {
  BOOKING_NEW
  BOOKINK_REQUESTED
  BOOKING_ACCEPTED
  BOOKING_REJECTED
  BOOKING_COMPLETED
  BOOKING_IN_PROGRESS
  BOOKING_CANCELLED
  PAYMENT_RECEIVED
  PAYMENT_RELEASED
  MESSAGE_NEW
  REVIEW_NEW
  PAYMENT_FAILED
  PAYMENT_REFUNDED
  SUBSCRIPTION_RENEWAL
  PAYMENT_SUCCESS
  PAYMENT_CANCELLED
  WITHDRAW_REQUEST
  WITHDRAWAL_APPROVED
  WITHDRAWAL_REJECTED
  SUBSCRIPTION_EXPIRING
  SYSTEM
  PROFILE_UPDATE
  PROFILE_APPROVED
  PROFILE_REJECTED
  SETTINGS_UPDATE

  REGISTRATION_SUCCESS
  ADMMIN_PERMISSION_GRANTED
  USER_ADMIN_PERMISSION_GRANTED
  BOOKING_PERMISSION_GRANTED
  CATEGORY_PERMISSION_GRANTED
  TRANSACTION_PERMISSION_GRANTED
  PROVIDER_PERMISSION_GRANTED
  WITHDRAWAL_PERMISSION_GRANTED
  ADMMIN_PERMISSION_REVOKED
  USER_ADMIN_PERMISSION_REVOKED
  BOOKING_PERMISSION_REVOKED
  CATEGORY_PERMISSION_REVOKED
  TRANSACTION_PERMISSION_REVOKED
  PROVIDER_PERMISSION_REVOKED
  WITHDRAWAL_PERMISSION_REVOKED
}

// ENUMS — new
// ─────────────────────────────────────────────────────────────────────────────
